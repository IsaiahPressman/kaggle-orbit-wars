# syntax=docker/dockerfile:1.7

# This is gcr.io/kaggle-images/python-simulations:latest as of 5/7/26
ARG KAGGLE_IMAGE=gcr.io/kaggle-images/python-simulations@sha256:53e8066187b5f46dfebf2a5b05bd5913e23c6c54a688e03700da3cb9da38ec76
FROM --platform=linux/amd64 ${KAGGLE_IMAGE}

ARG TARGETPLATFORM
ARG JUST_VERSION=1.50.0

ENV DEBIAN_FRONTEND=noninteractive \
    PYTHONUNBUFFERED=1 \
    CARGO_HOME=/opt/cargo \
    RUSTUP_HOME=/opt/rustup \
    VIRTUAL_ENV=/opt/kaggle-build-venv \
    PATH=/opt/kaggle-build-venv/bin:/opt/cargo/bin:$PATH

RUN test "${TARGETPLATFORM}" = "linux/amd64" || \
    (echo "Kaggle Python images target linux/amd64. Build with: docker build --platform linux/amd64 -f Dockerfile.kaggle -t orbit-wars:kaggle ." >&2 && exit 1)

RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        build-essential \
        ca-certificates \
        curl \
        git \
        pkg-config && \
    rm -rf /var/lib/apt/lists/*

RUN python -c 'import sys; assert sys.version_info >= (3, 11), f"Python 3.11+ required, found {sys.version}"'

WORKDIR /workspace/orbit-wars

COPY rust-toolchain.toml ./

RUN curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | \
    sh -s -- -y --profile minimal --default-toolchain none && \
    RUST_TOOLCHAIN="$(sed -n 's/^channel = "\(.*\)"/\1/p' rust-toolchain.toml)" && \
    test -n "${RUST_TOOLCHAIN}" && \
    rustup toolchain install "${RUST_TOOLCHAIN}" --profile minimal \
        --component rustfmt && \
    rustup default "${RUST_TOOLCHAIN}" && \
    cargo install just --version "${JUST_VERSION}" --locked && \
    python -m pip install --no-cache-dir uv && \
    uv venv --system-site-packages "${VIRTUAL_ENV}" && \
    uv pip install --python "${VIRTUAL_ENV}/bin/python" "maturin>=1.13.1,<2.0"

ENV UV_PYTHON=/opt/kaggle-build-venv/bin/python \
    UV_NO_MANAGED_PYTHON=1 \
    PYO3_PYTHON=/opt/kaggle-build-venv/bin/python

COPY Cargo.toml Cargo.lock pyproject.toml rustfmt.toml ./
COPY .cargo/ .cargo/
COPY src/lib.rs src/lib.rs

RUN --mount=type=cache,target=/opt/cargo/registry \
    --mount=type=cache,target=/opt/cargo/git \
    cargo fetch --locked

COPY . .

RUN --mount=type=cache,target=/opt/cargo/registry \
    --mount=type=cache,target=/opt/cargo/git \
    --mount=type=cache,target=/workspace/orbit-wars/target \
    uv run --active python -c 'import os, sys; assert sys.version_info[:2] == (3, 11), f"uv must use Python 3.11, found {sys.version} at {sys.executable}"; expected = os.path.realpath(os.path.join(os.environ["VIRTUAL_ENV"], "bin", "python")); actual = os.path.realpath(sys.executable); assert actual == expected, f"uv must use Kaggle venv Python at {expected}, found {actual}"' && \
    uv run --active maturin develop --release && \
    uv run --active python -c 'import owl.rs; owl.rs.assert_release_build()'

ENTRYPOINT ["scripts/build_kaggle_submission.sh"]
CMD ["--help"]
